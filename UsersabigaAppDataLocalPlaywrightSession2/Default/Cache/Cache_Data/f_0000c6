        video.src = objectUrl;
        const mimeCandidates = [
            'video/mp4;codecs="avc1.42E01E,mp4a.40.2"',
            "video/mp4"
        ];
        const mimeType = mimeCandidates.find((candidate)=>MediaRecorder.isTypeSupported(candidate));
        if (!mimeType) {
            URL.revokeObjectURL(objectUrl);
            return null;
        }
