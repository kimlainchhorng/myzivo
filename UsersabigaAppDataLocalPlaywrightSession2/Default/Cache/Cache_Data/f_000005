LE POLISH FIXES\r\n   ============================================= */\r\n\r\n/* Safari Glassmorphism Fix - GPU accelerated */\r\n\r\n.glass-panel {\r\n  backdrop-filter: blur(20px);\r\n  /* Triggers GPU acceleration to prevent flickering */\r\n  transform: translateZ(0);\r\n  will-change: transform;\r\n}\r\n\r\n/* Smooth momentum scrolling for touch devices */\r\n\r\n.scroll-touch {\r\n  -webkit-overflow-scrolling: touch;\r\n}\r\n\r\n/* iOS input zoom prevention already at line 482-486 */\r\n\r\n/* hide-scrollbar already at line 490-496 */\r\n\r\n/* Map marker drop-in bounce animation */\r\n\r\n@keyframes markerDropIn {\r\n  0% {\r\n    opacity: 0;\r\n    transform: scale(0.3) translateY(-20px);\r\n  }\r\n  100% {\r\n    opacity: 1;\r\n    transform: scale(1) translateY(0);\r\n  }\r\n}\r\n\r\n/* =============================================\r\n   SLIDE & SHIMMER ANIMATIONS 2026\r\n   ============================================= */\r\n\r\n/* Horizontal slide for image carousels */\r\n\r\n@keyframes slide-left-infinite {\r\n  0% { transform: translateX(0); }\r\n  100% { transform: translateX(-50%); }\r\n}\r\n\r\n@keyframes slide-right-infinite {\r\n  0% { transform: translateX(-50%); }\r\n  100% { transform: translateX(0); }\r\n}\r\n\r\n.animate-slide-left {\r\n  animation: slide-left-infinite 30s linear infinite;\r\n}\r\n\r\n.animate-slide-right {\r\n  animation: slide-right-infinite 30s linear infinite;\r\n}\r\n\r\n/* Ken Burns effect for hero images */\r\n\r\n@keyframes ken-burns {\r\n  0% { transform: scale(1) translate(0, 0); }\r\n  25% { transform: scale(1.05) translate(-1%, -1%); }\r\n  50% { transform: scale(1.08) translate(1%, 0); }\r\n  75% { transform: scale(1.05) translate(0, 1%); }\r\n  100% { transform: scale(1) translate(0, 0); }\r\n}\r\n\r\n.animate-ken-burns {\r\n  animation: ken-burns 20s ease-in-out infinite;\r\n}\r\n\r\n/* Shimmer overlay for premium cards */\r\n\r\n@keyframes shimmer-slide {\r\n  0% { transform: translateX(-100%); }\r\n  100% { transform: translateX(200%); }\r\n}\r\n\r\n.shimmer-overlay::after {\r\n  content: '';\r\n  position: absolute;\r\n  inset: 0;\r\n  background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.08) 50%, transparent 100%);\r\n  animation: shimmer-slide 3s ease-in-out infinite;\r\n  pointer-events: none;\r\n}\r\n\r\n/* Subtle parallax float */\r\n\r\n@keyframes parallax-float {\r\n  0%, 100% { transform: translateY(0) rotate(0deg); }\r\n  33% { transform: translateY(-8px) rotate(0.5deg); }\r\n  66% { transform: translateY(4px) rotate(-0.3deg); }\r\n}\r\n\r\n.animate-parallax-float {\r\n  animation: parallax-float 6s ease-in-out infinite;\r\n}\r\n\r\n/* Image reveal slide */\r\n\r\n@keyframes reveal-left {\r\n  from { clip-path: inset(0 100% 0 0); }\r\n  to { clip-path: inset(0 0 0 0); }\r\n}\r\n\r\n@keyframes reveal-up {\r\n  from { clip-path: inset(100% 0 0 0); }\r\n  to { clip-path: inset(0 0 0 0); }\r\n}\r\n\r\n.animate-reveal-left {\r\n  animation: reveal-left 0.8s ease-out forwards;\r\n}\r\n\r\n.animate-reveal-up {\r\n  animation: reveal-up 0.8s ease-out forwards;\r\n}\r\n\r\n/* Reduced motion preference */\r\n\r\n@media (prefers-reduced-motion: reduce) {\r\n  *, *::before, *::after {\r\n    animation-duration: 0.01ms !important;\r\n    animation-iteration-count: 1 !important;\r\n    transition-duration: 0.01ms !important;\r\n    scroll-behavior: auto !important;\r\n  }\r\n  .text-shimmer,\r\n  .bg-gradient-animated,\r\n  .animate-spin,\r\n  .animate-pulse,\r\n  .animate-bounce {\r\n    animation: none !important;\r\n  }\r\n}\r\n\r\n/* Focus-visible ring for keyboard navigation */\r\n\r\n:focus-visible {\r\n  outline: 2px solid hsl(var(--primary));\r\n  outline-offset: 2px;\r\n  border-radius: 4px;\r\n}\r\n\r\n/* Smooth scroll globally */\r\n\r\nhtml {\r\n  scroll-behavior: smooth;\r\n}\r\n\r\n/* ═══ Service Icon Tap Animations ═══ */\r\n\r\n/* 🚗 Car: 3D driving wiggle */\r\n\r\n@keyframes car-run {\r\n  0% { transform: translateX(0) translateY(0) rotateY(0deg) scale(1); }\r\n  10% { transform: translateX(-4px) translateY(-2px) rotateY(-12deg) scale(1.06); }\r\n  20% { transform: translateX(-2px) translateY(1px) rotateY(-6deg) scale(1.1); }\r\n  35% { transform: translateX(3px) translateY(-2px) rotateY(8deg) scale(1.08); }\r\n  50% { transform: translateX(6px) translateY(1px) rotateY(14deg) scale(1.1); }\r\n  65% { transform: translateX(3px) translateY(-1px) rotateY(6deg) scale(1.06); }\r\n  80% { transform: translateX(-2px) translateY(1px) rotateY(-4deg) scale(1.03); }\r\n  100% { transform: translateX(0) translateY(0) rotateY(0deg) scale(1); }\r\n}\r\n\r\n.animate-car-run {\r\n  animation: car-run 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;\r\n  transform-style: preserve-3d;\r\n}\r\n\r\n/* ✈️ Plane: fly up-right with tilt and swoop back */\r\n\r\n@keyframes plane-fly {\r\n  0% { transform: translate(0, 0) rotate(0deg) scale(1); }\r\n  10% { transform: translate(3px, -4px) rotate(-12deg) scale(1.05); }\r\n  25% { transform: translate(10px, -14px) rotate(-20deg) scale(1.12); }\r\n  40% { transform: translate(18px, -22px) rotate(-25deg) scale(1.08); opacity: 0.6; }\r\n  50% { transform: translate(24px, -28px) rotate(-28deg) scale(0.95); opacity: 0; }\r\n  51% { transform: translate(-20px, 16px) rotate(10deg) scale(0.8); opacity: 0; }\r\n  65% { transform: translate(-12px, 8px) rotate(5deg) scale(0.95); opacity: 0.6; }\r\n  80% { transform: translate(-4px, 2px) rotate(-3deg) scale(1.05); opacity: 0.9; }\r\n  90% { transform: translate(-1px, 0px) rotate(-1deg) scale(1.02); }\r\n  100% { transform: translate(0, 0) rotate(0deg) scale(1); opacity: 1; }\r\n}\r\n\r\n.animate-plane-fly {\r\n  animation: plane-fly 0.85s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;\r\n}\r\n\r\n/* 📦 Package: drop bounce */\r\n\r\n@keyframes pkg-bounce {\r\n  0% { transform: translateY(0) scale(1); }\r\n  12% { transform: translateY(-16px) scale(1.05); }\r\n  28% { transform: translateY(0) scale(0.92, 1.08); }\r\n  40% { transform: translateY(-8px) scale(1.04); }\r\n  54% { transform: translateY(0) scale(0.95, 1.05); }\r\n  66% { transform: translateY(-3px) scale(1.02); }\r\n  80% { transform: translateY(0) scale(0.98, 1.02); }\r\n  100% { transform: translateY(0) scale(1); }\r\n}\r\n\r\n.animate-pkg-bounce {\r\n  animation: pkg-bounce 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;\r\n}\r\n\r\n/* 🍔 Food/Shopping: excited wiggle */\r\n\r\n@keyframes food-wiggle {\r\n  0% { transform: rotate(0deg) scale(1); }\r\n  10% { transform: rotate(-12deg) scale(1.08); }\r\n  20% { transform: rotate(10deg) scale(1.1); }\r\n  30% { transform: rotate(-10deg) scale(1.12); }\r\n  42% { transform: rotate(8deg) scale(1.1); }\r\n  54% { transform: rotate(-6deg) scale(1.08); }\r\n  66% { transform: rotate(4deg) scale(1.05); }\r\n  78% { transform: rotate(-2deg) scale(1.02); }\r\n  90% { transform: rotate(1deg) scale(1.01); }\r\n  100% { transform: rotate(0deg) scale(1); }\r\n}\r\n\r\n.animate-food-wiggle {\r\n  animation: food-wiggle 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;\r\n}\r\n\r\n@media (prefers-reduced-motion: reduce) {\r\n  html { scroll-behavior: auto; }\r\n  .animate-car-run,\r\n  .animate-plane-fly,\r\n  .animate-pkg-bounce,\r\n  .animate-food-wiggle {\r\n    animation: none;\r\n  }\r\n}\r\n\r\n/* ── Khmer Language Typography ── */\r\n\r\nhtml[lang=\"km\"],\r\nhtml[lang=\"km\"] body,\r\nhtml[lang=\"km\"] * {\r\n  font-family: 'Battambang', 'Noto Sans Khmer', 'Work Sans', system-ui, sans-serif;\r\n}\r\n\r\nhtml[lang=\"km\"] h1,\r\nhtml[lang=\"km\"] h2,\r\nhtml[lang=\"km\"] h3,\r\nhtml[lang=\"km\"] h4,\r\nhtml[lang=\"km\"] h5,\r\nhtml[lang=\"km\"] h6,\r\nhtml[lang=\"km\"] .font-semibold,\r\nhtml[lang=\"km\"] .font-bold,\r\nhtml[lang=\"km\"] .font-extrabold {\r\n  font-family: 'Battambang', 'Noto Sans Khmer', sans-serif;\r\n  font-weight: 700;\r\n}\r\n\r\nhtml[lang=\"km\"] p,\r\nhtml[lang=\"km\"] span,\r\nhtml[lang=\"km\"] a,\r\nhtml[lang=\"km\"] button,\r\nhtml[lang=\"km\"] label,\r\nhtml[lang=\"km\"] input,\r\nhtml[lang=\"km\"] textarea {\r\n  font-family: 'Noto Sans Khmer', 'Battambang', 'Work Sans', sans-serif;\r\n  letter-spacing: 0.01em;\r\n  line-height: 1.6;\r\n}\r\n\r\n/* =============================================\r\n   3D SPATIAL UI SYSTEM — 2026 Alive UX\r\n   ============================================= */\r\n\r\n.perspective-container {\r\n  perspective: 1200px;\r\n  perspective-origin: 50% 50%;\r\n}\r\n\r\n.preserve-3d {\r\n  transform-style: preserve-3d;\r\n}\r\n\r\n.card-3d {\r\n  transform-style: preserve-3d;\r\n  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.4s ease;\r\n  will-change: transform;\r\n}\r\n\r\n.card-3d:hover {\r\n  transform: translateY(-8px) translateZ(20px) rotateX(2deg);\r\n  box-shadow: 0 25px 50px -12px hsl(var(--primary) / 0.15), 0 12px 24px -8px hsl(0 0% 0% / 0.1);\r\n}\r\n\r\n.card-3d:active {\r\n  transform: translateY(-2px) translateZ(5px) scale(0.98);\r\n}\r\n\r\n.btn-3d {\r\n  transform-style: preserve-3d;\r\n  position: relative;\r\n  transition: all 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);\r\n  box-shadow:\r\n    0 4px 0 hsl(var(--primary) / 0.4),\r\n    0 6px 20px hsl(var(--primary) / 0.2);\r\n}\r\n\r\n.btn-3d:hover {\r\n  transform: translateY(-2px) translateZ(8px);\r\n  box-shadow:\r\n    0 6px 0 hsl(var(--primary) / 0.4),\r\n    0 10px 30px hsl(var(--primary) / 0.3);\r\n}\r\n\r\n.btn-3d:active {\r\n  transform: translateY(2px) translateZ(0px);\r\n  box-shadow:\r\n    0 1px 0 hsl(var(--primary) / 0.4),\r\n    0 2px 8px hsl(var(--primary) / 0.15);\r\n}\r\n\r\n.icon-3d-pop {\r\n  transform-style: preserve-3d;\r\n  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);\r\n}\r\n\r\n.icon-3d-pop:hover {\r\n  transform: translateY(-6px) translateZ(15px) scale(1.1);\r\n  filter: drop-shadow(0 8px 16px hsl(var(--primary) / 0.2));\r\n}\r\n\r\n@keyframes orb-float-1 {\r\n  0%, 100% { transform: translate(0, 0) scale(1); }\r\n  25% { transform: translate(30px, -20px) scale(1.1); }\r\n  50% { transform: translate(-20px, -40px) scale(0.95); }\r\n  75% { transform: translate(15px, -10px) scale(1.05); }\r\n}\r\n\r\n@keyframes orb-float-2 {\r\n  0%, 100% { transform: translate(0, 0) scale(1); }\r\n  33% { transform: translate(-40px, 20px) scale(1.15); }\r\n  66% { transform: translate(25px, -30px) scale(0.9); }\r\n}\r\n\r\n.orb-3d-1 {\r\n  position: absolute;\r\n  width: 300px;\r\n  height: 300px;\r\n  border-radius: 50%;\r\n  background: radial-gradient(circle, hsl(var(--primary) / 0.12), transparent 70%);\r\n  filter: blur(60px);\r\n  animation: orb-float-1 8s ease-in-out infinite;\r\n  pointer-events: none;\r\n}\r\n\r\n.orb-3d-2 {\r\n  position: absolute;\r\n  width: 250px;\r\n  height: 250px;\r\n  border-radius: 50%;\r\n  background: radial-gradient(circle, hsl(var(--flights) / 0.1), transparent 70%);\r\n  filter: blur(50px);\r\n  animation: orb-float-2 10s ease-in-out infinite;\r\n  pointer-events: none;\r\n}\r\n\r\n.bg-mesh-3d {\r\n  background:\r\n    radial-gradient(ellipse at 20% 50%, hsl(var(--primary) / 0.06), transparent 50%),\r\n    radial-gradient(ellipse at 80% 20%, hsl(var(--flights) / 0.05), transparent 50%),\r\n    radial-gradient(ellipse at 50% 80%, hsl(var(--hotels) / 0.04), transparent 50%);\r\n}\r\n\r\n.glass-3d {\r\n  background: hsl(var(--card) / 0.7);\r\n  backdrop-filter: blur(24px) saturate(180%);\r\n  -webkit-backdrop-filter: blur(24px) saturate(180%);\r\n  border: 1px solid hsl(var(--border) / 0.3);\r\n  box-shadow:\r\n    0 8px 32px hsl(0 0% 0% / 0.06),\r\n    inset 0 1px 0 hsl(0 0% 100% / 0.1);\r\n  transform-style: preserve-3d;\r\n}\r\n\r\n.tab-3d {\r\n  transform-style: preserve-3d;\r\n  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);\r\n}\r\n\r\n.tab-3d.active {\r\n  transform: translateY(-3px) translateZ(10px);\r\n  box-shadow: 0 8px 24px hsl(var(--primary) / 0.3);\r\n}\r\n\r\n.tab-3d:not(.active):hover {\r\n  transform: translateY(-1px) translateZ(5px);\r\n}\r\n\r\n@keyframes breathe-glow {\r\n  0%, 100% { opacity: 0.3; transform: scale(1); }\r\n  50% { opacity: 0.6; transform: scale(1.05); }\r\n}\r\n\r\n.breathe-glow {\r\n  animation: breathe-glow 4s ease-in-out infinite;\r\n}\r\n\r\n@keyframes foilShimmer {\r\n  0%, 100% { background-position: 200% 200%; }\r\n  50% { background-position: 0% 0%; }\r\n}\r\n\r\n@media (prefers-reduced-motion: reduce) {\r\n  .card-3d, .btn-3d, .tab-3d, .icon-3d-pop {\r\n    transform: none !important;\r\n    transition: opacity 0.2s ease !important;\r\n  }\r\n  .orb-3d-1, .orb-3d-2, .breathe-glow {\r\n    animation: none !important;\r\n  }\r\n}\r\n\r\n/* =============================================\r\n   ZIVO SIGNATURE DESIGN LANGUAGE (2026)\r\n   Unique identity — NOT copied from any platform\r\n   ============================================= */\r\n\r\n/* Aurora Mesh Background */\r\n\r\n.zivo-aurora {\r\n  background:\r\n    radial-gradient(ellipse 80% 50% at 20% 40%, hsl(142 71% 45% / 0.08), transparent),\r\n    radial-gradient(ellipse 60% 80% at 80% 60%, hsl(198 93% 59% / 0.06), transparent),\r\n    radial-gradient(ellipse 40% 40% at 50% 20%, hsl(263 70% 58% / 0.04), transparent);\r\n}\r\n\r\n/* ZIVO Emerald Ribbon — signature top accent */\r\n\r\n.zivo-ribbon {\r\n  position: relative;\r\n  overflow: hidden;\r\n}\r\n\r\n.zivo-ribbon::before {\r\n  content: '';\r\n  position: absolute;\r\n  top: 0; left: 0; right: 0;\r\n  height: 3px;\r\n  background: linear-gradient(90deg, hsl(142 71% 45%), hsl(172 66% 50%), hsl(198 93% 59%));\r\n  border-radius: 0 0 4px 4px;\r\n}\r\n\r\n/* Organic Blob Card */\r\n\r\n.zivo-card-organic {\r\n  background: hsl(var(--card));\r\n  border: 1px solid hsl(var(--border) / 0.3);\r\n  border-radius: 20px;\r\n  position: relative;\r\n  overflow: hidden;\r\n  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;\r\n}\r\n\r\n.zivo-card-organic:active {\r\n  transform: scale(0.97);\r\n}\r\n\r\n.zivo-card-organic::after {\r\n  content: '';\r\n  position: absolute;\r\n  top: -30%; right: -20%;\r\n  width: 60%;\r\n  height: 60%;\r\n  background: radial-gradient(circle, hsl(var(--primary) / 0.04), transparent 70%);\r\n  pointer-events: none;\r\n}\r\n\r\n/* ZIVO Icon Pill — signature rounded-square icon container */\r\n\r\n.zivo-icon-pill {\r\n  width: 44px;\r\n  height: 44px;\r\n  border-radius: 14px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  position: relative;\r\n  overflow: hidden;\r\n  flex-shrink: 0;\r\n}\r\n\r\n.zivo-icon-pill::before {\r\n  content: '';\r\n  position: absolute;\r\n  inset: 0;\r\n  background: linear-gradient(135deg, currentColor, transparent);\r\n  opacity: 0.1;\r\n  border-radius: inherit;\r\n}\r\n\r\n/* ZIVO Section Divider — organic wave line */\r\n\r\n.zivo-divider {\r\n  height: 1px;\r\n  background: linear-gradient(90deg, transparent, hsl(var(--border) / 0.6) 30%, hsl(var(--border) / 0.6) 70%, transparent);\r\n  margin: 1.5rem 0;\r\n}\r\n\r\n/* ZIVO Floating Badge */\r\n\r\n.zivo-badge {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  gap: 4px;\r\n  padding: 2px 8px;\r\n  border-radius: 8px;\r\n  font-size: 10px;\r\n  font-weight: 700;\r\n  letter-spacing: 0.02em;\r\n  background: linear-gradient(135deg, hsl(var(--primary) / 0.15), hsl(var(--primary) / 0.05));\r\n  color: hsl(var(--primary));\r\n  border: 1px solid hsl(var(--primary) / 0.2);\r\n}\r\n\r\n/* ZIVO Signature Button */\r\n\r\n.zivo-btn-signature {\r\n  background: linear-gradient(135deg, hsl(142 71% 45%), hsl(158 64% 51%));\r\n  color: white;\r\n  border: none;\r\n  border-radius: 16px;\r\n  font-weight: 700;\r\n  position: relative;\r\n  overflow: hidden;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.zivo-btn-signature::before {\r\n  content: '';\r\n  position: absolute;\r\n  top: 0; left: -100%;\r\n  width: 50%;\r\n  height: 100%;\r\n  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);\r\n  transition: left 0.5s ease;\r\n}\r\n\r\n.zivo-btn-signature:hover::before {\r\n  left: 100%;\r\n}\r\n\r\n.zivo-btn-signature:active {\r\n  transform: scale(0.97);\r\n}\r\n\r\n/* ZIVO Stat Orb — circular stat display */\r\n\r\n.zivo-stat-orb {\r\n  width: 72px;\r\n  height: 72px;\r\n  border-radius: 50%;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  background: hsl(var(--card));\r\n  border: 2px solid hsl(var(--border) / 0.4);\r\n  box-shadow: 0 4px 16px hsl(var(--primary) / 0.06);\r\n}\r\n\r\n/* ZIVO Category Chip */\r\n\r\n.zivo-chip {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  gap: 6px;\r\n  padding: 6px 14px;\r\n  border-radius: 12px;\r\n  font-size: 13px;\r\n  font-weight: 600;\r\n  background: hsl(var(--muted) / 0.5);\r\n  color: hsl(var(--foreground));\r\n  border: 1px solid hsl(var(--border) / 0.3);\r\n  transition: all 0.2s ease;\r\n  cursor: pointer;\r\n}\r\n\r\n.zivo-chip:hover, .zivo-chip.active {\r\n  background: hsl(var(--primary) / 0.1);\r\n  border-color: hsl(var(--primary) / 0.3);\r\n  color: hsl(var(--primary));\r\n}\r\n\r\n/* ZIVO Progress Ring */\r\n\r\n@keyframes zivo-ring-fill {\r\n  from { stroke-dashoffset: 283; }\r\n}\r\n\r\n/* ZIVO Mesh Grid Background */\r\n\r\n.zivo-mesh-grid {\r\n  background-image:\r\n    linear-gradient(hsl(var(--border) / 0.08) 1px, transparent 1px),\r\n    linear-gradient(90deg, hsl(var(--border) / 0.08) 1px, transparent 1px);\r\n  background-size: 32px 32px;\r\n}\r\n\r\n/* ZIVO Watermark */\r\n\r\n.zivo-watermark {\r\n  position: absolute;\r\n  bottom: -20px;\r\n  right: -10px;\r\n  font-size: 80px;\r\n  font-weight: 900;\r\n  letter-spacing: -4px;\r\n  color: hsl(var(--foreground) / 0.02);\r\n  pointer-events: none;\r\n  -webkit-user-select: none;\r\n     -moz-user-select: none;\r\n          user-select: none;\r\n}\r\n\r\n@keyframes zivo-float {\r\n  0%, 100% { transform: translateY(0px); }\r\n  50% { transform: translateY(-6px); }\r\n}\r\n\r\n.zivo-float {\r\n  animation: zivo-float 3s ease-in-out infinite;\r