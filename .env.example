# ============================================================
# ZIVO — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Public anon key (safe to expose in frontend JS)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PROJECT_ID=<project-ref>

# Service role key — BACKEND ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ──────────────────────────────────────────────────
# Publishable key (safe for frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Secret key — BACKEND ONLY
STRIPE_SECRET_KEY=sk_live_...
# Webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Google ──────────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=AIza...
GOOGLE_OAUTH_CLIENT_ID=<client-id>.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...

# ── Mapbox ──────────────────────────────────────────────────
# Public token (safe for frontend)
VITE_MAPBOX_ACCESS_TOKEN=pk.eyJ...
# Secret token — BACKEND ONLY
MAPBOX_SECRET_TOKEN=sk.eyJ...

# ── Twilio (SMS / WhatsApp) ──────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ── LiveKit (Video / WebRTC) ─────────────────────────────────
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...
VITE_LIVEKIT_URL=wss://<project>.livekit.cloud

# ── TravelPayouts / Duffel ───────────────────────────────────
VITE_TRAVELPAYOUTS_MARKER=<marker>
DUFFEL_API_KEY=duffel_live_...

# ── Meta / Facebook ──────────────────────────────────────────
VITE_META_PIXEL_ID=<pixel-id>

# ── App ──────────────────────────────────────────────────────
VITE_APP_URL=https://myzivo.com
VITE_AVIASALES_WL_BASE_URL=https://aviasales.com
