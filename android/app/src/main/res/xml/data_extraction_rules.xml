<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ data-extraction rules.

  We disable cloud backup and device-to-device transfer for sensitive data:
  - app preferences containing auth tokens
  - WebView local storage / IndexedDB (where Supabase persists the session)
  - any file under "files/" that's user-private

  Reference: https://developer.android.com/about/versions/12/backup-restore
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
