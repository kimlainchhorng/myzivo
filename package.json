    "security:api-readiness:report": "node scripts/security/api-readiness-check.mjs --write-report",
    "security:scan": "npm run security:audit && npm run security:check-secrets",
    "deploy:update": "node scripts/deploy-update.mjs",
    "import:hotels": "bun scripts/import-hotel-data.ts",
    "import:hotels:dry": "bun scripts/import-hotel-data.ts --dry-run",
